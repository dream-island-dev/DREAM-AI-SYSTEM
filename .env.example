# העתק ל-.env מקומי (לפיתוח) ו/או הגדר ב-Vercel ▸ Settings ▸ Environment Variables.
# ב-Create React App כל משתנה חייב להתחיל ב-REACT_APP_ ומוטמע בזמן build.
# אל תעלה את .env (עם הערכים האמיתיים) ל-GitHub.

# כתובת ה-Web App של ה-Apps Script (מסתיימת ב-/exec)
REACT_APP_BACKEND_URL=https://script.google.com/macros/s/XXXXXXXX/exec

# ה-OAuth Client ID שיצרת ב-Google Cloud Console
REACT_APP_GOOGLE_CLIENT_ID=XXXXXXXX.apps.googleusercontent.com
