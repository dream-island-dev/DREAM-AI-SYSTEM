# =============================================================
# Dream Island AI System — Environment Variables
# Copy this file to .env (for local dev) or set in Vercel/Netlify.
# NEVER commit .env with real values to Git.
# All REACT_APP_* vars are embedded at build time (CRA).
# =============================================================

# ── Google OAuth ──────────────────────────────────────────────
# OAuth Client ID from Google Cloud Console → APIs & Services → Credentials
REACT_APP_GOOGLE_CLIENT_ID=XXXXXXXX.apps.googleusercontent.com

# ── Legacy Backend (Google Apps Script) ───────────────────────
# Keep this if you're still using the Apps Script backend.
# When migrating to Supabase Edge Functions, leave it empty.
REACT_APP_BACKEND_URL=https://script.google.com/macros/s/XXXXXXXX/exec

# ── Supabase (Production) ─────────────────────────────────────
# Get these from: Supabase Dashboard → Settings → API
REACT_APP_SUPABASE_URL=https://XXXXXXXX.supabase.co
REACT_APP_SUPABASE_ANON_KEY=eyXXXXXXXX...

# ── Supabase Edge Function Secrets ───────────────────────────
# Set via: supabase secrets set KEY=value
# Do NOT set as REACT_APP_* — that exposes them to the browser.

# Anthropic API key
# ANTHROPIC_API_KEY=sk-ant-XXXXXXXX

# Google Drive RAG Bridge:
# 1. Open Code.gs in Google Apps Script (Extensions → Apps Script)
# 2. Deploy → New deployment → Web App → Execute as: Me, Anyone can access
# 3. Paste the /exec URL below
# APPS_SCRIPT_URL=https://script.google.com/macros/s/XXXXXXXX/exec
